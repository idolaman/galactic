{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".mcp-build-cache/unit-tests",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "tests/unit/**/*.ts",
    "src/lib/app-toast.ts",
    "src/lib/create-workspace-toast.ts",
    "src/lib/create-workspace-flow.ts",
    "src/lib/load-project-branches.ts",
    "src/lib/create-workspace-request.ts",
    "src/lib/async-toggle-setting.ts",
    "src/lib/toast-defaults.ts",
    "src/lib/mcp-installation.ts",
    "src/lib/mcp-installation-details.ts",
    "src/lib/workspace-session-display.ts"
  ]
}
