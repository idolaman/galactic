{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".mcp-build-cache/unit-tests",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "tests/unit/**/*.ts",
    "src/lib/app-toast.ts",
    "src/lib/auth-analytics.ts",
    "src/lib/auth-callback.ts",
    "src/lib/auth-session-transition.ts",
    "src/lib/auth-sign-in-view-state.ts",
    "src/lib/create-workspace-toast.ts",
    "src/lib/create-workspace-flow.ts",
    "src/lib/load-project-branches.ts",
    "src/lib/project-list-state.ts",
    "src/lib/create-workspace-request.ts",
    "src/lib/async-toggle-setting.ts",
    "src/lib/toast-defaults.ts",
    "src/lib/mcp-installation.ts",
    "src/lib/mcp-installation-details.ts",
    "src/lib/workspace-session-display.ts",
    "src/services/local-storage-keys.ts",
    "src/services/local-storage-migration.ts",
    "src/services/local-storage-scope.ts",
    "src/types/auth.ts"
  ]
}
